[server]
port = 8080
workers = 16

[database]
psql_connstring = "dbname=hyperscraper user=hyperscraper"

[general]
version = 4 # The coordinator version

worker_timeout = 600 # Disconect workers if they're idle for 10 minutes

trust_count = 2 # How many workers need to download the same chunk before we trust that it is accurate (obviouly a higher number slows down the ov>

[paths]
chunk_temp_path = "/opt/temp/"
storage_path = "/mnt/cephfs/hyperscrape/"